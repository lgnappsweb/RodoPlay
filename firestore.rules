rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Player profiles and statistics
    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == playerId || playerId.startsWith('p_') || request.auth == null;
    }

    // Mandatory master users collection
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId || userId.startsWith('p_') || request.auth == null;
    }

    // Real-time global, bases, and shift rankings collections
    match /rankings/global/players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == playerId || playerId.startsWith('p_') || request.auth == null;
    }

    match /rankings/bases/all_bases/{baseId}/players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == playerId || playerId.startsWith('p_') || request.auth == null;
    }

    match /rankings/turnos/all_turnos/{turnoId}/players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == playerId || playerId.startsWith('p_') || request.auth == null;
    }
    
    // Real-time multiplayer rooms
    match /multiplayer_rooms/{roomId} {
      allow read, write: if true;
    }
    
    // Direct player invitations
    match /invitations/{invitationId} {
      allow read, write: if true;
    }

    // Player notifications
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    
    // Base/shift performance statistics
    match /stats/{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // Game history and duel logs
    match /duels/{duelId} {
      allow read: if true;
      allow write: if true;
    }

    // Active sessions for multi-device synchronization
    match /sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
